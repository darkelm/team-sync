# Provider mode: "local" or "live" per integration
JIRA_PROVIDER=local
CONFLUENCE_PROVIDER=local
GITHUB_PROVIDER=local
SLACK_PROVIDER=local
FIGMA_PROVIDER=local

# Atlassian (Jira + Confluence)
ATLASSIAN_URL=https://yourname.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# Figma
FIGMA_ACCESS_TOKEN=
# Optional: explicit design-system library file key(s), comma-separated.
# If unset, the key is parsed from each team manifest's design_system_library URL.
# Example: FIGMA_LIBRARY_FILE_KEY=nova-design-system,abc123
FIGMA_LIBRARY_FILE_KEY=
# Webhook passcode for Figma push events (used by the webhook receiver in C1)
FIGMA_WEBHOOK_PASSCODE=

# Anthropic — set this to switch the Slack bot from keyword matching to
# natural-language understanding (Claude agent). No other change needed.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8)
ANTHROPIC_MODEL=

# Webhook receiver secrets (webhook_server.py — runs as a SEPARATE process from slack_bot.py)
# GitHub: HMAC-SHA256 over raw body; set in GitHub App / repo webhook settings
GITHUB_WEBHOOK_SECRET=
# Figma: passcode field in JSON payload; set when creating the Figma webhook subscription
FIGMA_WEBHOOK_PASSCODE=
# Jira: shared-secret header X-Webhook-Token; set in Jira automation webhook config
JIRA_WEBHOOK_TOKEN=
# Calendar + generic endpoints: shared-secret header X-Webhook-Token
WEBHOOK_SHARED_SECRET=

# Data paths
SYNTHETIC_DATA_PATH=./data/synthetic
TEAMS_DIR=./data/synthetic/teams
